# Sepsis Pipeline Environment Variables

# AWS 
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_DEFAULT_REGION=us-east-1
S3_BUCKET_NAME=sepsis-pipeline-yourname

# PostgreSQL (Gold layer) 
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=sepsis_gold
POSTGRES_USER=sepsis_admin
POSTGRES_PASSWORD=change_this_password

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Databricks 
DATABRICKS_HOST=https://community.cloud.databricks.com
DATABRICKS_TOKEN=your_token_here

# Amazon Bedrock 
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0
BEDROCK_REGION=us-east-1

#Pipeline Config 
REPLAY_SPEED_FACTOR=288
#288x means 24 hours of ICU data replays in 5 minutes
#(24*60/5 = 288)